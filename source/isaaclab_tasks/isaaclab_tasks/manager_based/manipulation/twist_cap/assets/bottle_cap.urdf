<?xml version="1.0"?>
<robot name="twist_cap_bottle">
  <material name="bottle_gray">
    <color rgba="0.72 0.72 0.72 1.0"/>
  </material>
  <material name="cap_orange">
    <color rgba="0.93 0.45 0.12 1.0"/>
  </material>

  <link name="bottle_link">
    <inertial>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <mass value="0.25"/>
      <inertia ixx="0.0012" ixy="0" ixz="0" iyy="0.0012" iyz="0" izz="0.0004"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.16"/>
      </geometry>
      <material name="bottle_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.16"/>
      </geometry>
    </collision>
  </link>

  <link name="cap_link">
    <inertial>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <mass value="0.04"/>
      <inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.00008" iyz="0" izz="0.00004"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.026" length="0.03"/>
      </geometry>
      <material name="cap_orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.026" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="cap_joint" type="revolute">
    <parent link="bottle_link"/>
    <child link="cap_link"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="1.57" effort="2.0" velocity="8.0"/>
    <dynamics damping="0.05" friction="0.02"/>
  </joint>
</robot>

